{"ts":1783836549,"hash":"19755e8bad758e08e758edff89e6ccb8c77175e88c06dd779d7f42d30d84122a","mode":"diff","ops":[{"tag":"insert","a1":1,"a2":1,"text":"\n"},{"tag":"replace","a1":2,"a2":6,"text":"\ntype bomb struct {\n\tx    int\n\ty    int\n\traio int\n"},{"tag":"insert","a1":7,"a2":7,"text":"\n"},{"tag":"replace","a1":8,"a2":13,"text":"\tn := 0\n    co:=0\n\tfmt.Scan(&n,&co)\n\tbomba := make([]bomb, n)\n\tfor i := 0; i < n; i++ {\n\t\tfmt.Scan(&bomba[i].x, &bomba[i].y, &bomba[i].raio)\n\t}\n\tgraph := buildgraph(bomba)\n\tmax := 0\n\tfor i := 0; i < n; i++ {\n\t\tans := bfs(i, graph, n)\n\t\tif ans > max {\n\t\t\tmax = ans\n\t\t}\n\t}\n\n\tfmt.Println(max)\n"},{"tag":"replace","a1":14,"a2":16,"text":"func buildgraph(bombas []bomb) [][]int {\n\tk := len(bombas)\n\tgraph := make([][]int, k)\n\tfor i := 0; i < k; i++ {\n\t\tfor j := 0; j < k; j++ {\n\t\t\tif i == j {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tl := bombas[i].y - bombas[j].y\n\t\t\to := bombas[i].x - bombas[j].x\n\t\t\tdq := (l * l) + (o * o)\n\t\t\trq := bombas[i].raio * bombas[i].raio\n\n\t\t\tif dq <= rq {\n\t\t\t\tgraph[i] = append(graph[i], j)\n\t\t\t}\n\t\t}\n\t}\n\treturn graph\n"},{"tag":"replace","a1":17,"a2":36,"text":"func bfs(start int, g [][]int, n int) int {\n\tvis := make([]bool, n)\n\tq := []int{start}\n\tvis[start] = true\n\tc := 1\n\tfor len(q) > 0 {\n\t\tu := q[0]\n\t\tq = q[1:]\n\t\tfor _, v := range g[u] {\n\t\t\tif !vis[v] {\n\t\t\t\tvis[v] = true\n\t\t\t\tq = append(q, v)\n\t\t\t\tc++\n\t\t\t}\n\t\t}\n\t}\n\treturn c\n"},{"tag":"delete","a1":37,"a2":55,"text":""}]}
