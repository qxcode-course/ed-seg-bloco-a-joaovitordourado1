{"ts":1783900477,"hash":"83b9b40c8d4a523dd3aefedb93efc6785b0c4a6b0b4f154404d5766d3cf95e43","mode":"diff","ops":[{"tag":"insert","a1":2,"a2":2,"text":"\nfunc aux(a[]byte,id,L int,char byte)bool{\n    for i := 0; i < L; i++ {\n        if id-i>=0 && a[id-i]== char{\n            return false\n        }\n    }\n    for i := 0; i < L; i++ {\n        if id+i< len(a)&& a[id+i]== char{\n            return false\n        }\n    }\n    return true\n}\nfunc back(a []byte,L,i int)bool{\n    if i == len(a){\n        return true\n    }\n    if a[i] != '.'{\n        return back(a,L,i+1)\n    }\n    for d := 0; d <= L; d++{\n        cd:= byte('0'+d)\n        if aux(a,i,L,cd){\n            a[i]=cd\n\n        }\n        if back(a,L,i){\n            return true\n        }\n        a[i]= '.'\n    }\n    return false\n}\n"},{"tag":"delete","a1":3,"a2":4,"text":""}]}
